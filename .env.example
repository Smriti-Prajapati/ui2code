# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ui2code
VECTOR_DB_PATH=./vector_db

# Model Paths
YOLO_MODEL_PATH=./model/yolov8_ui_detector.pt
DETECTRON2_CONFIG=./model/detectron2_config.yaml

# Server Configuration
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# Frontend URL (used for CORS — set to your Vercel URL in production)
FRONTEND_URL=http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp

# Code Generation
DEFAULT_FRAMEWORK=react
DEFAULT_STYLING=tailwind
